generator client {
  provider = "prisma-client-js"
}

    datasource db {
      provider = "postgresql"
      url      = env("DATABASE_URL")
    }

model Recipe {
  id          String   @id @default(cuid())
  name        String
  country     String
  image       String
  ingredients String
  steps       String
  time        Int
  difficulty  String
  createdAt   DateTime @default(now())
}